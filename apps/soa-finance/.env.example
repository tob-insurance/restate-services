# Application Environment (development | production)
APP_ENV=development
NODE_ENV=development
TEST_EMAIL_RECIPIENT=your-test-email@example.com

# Microsoft Graph API (email sending)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SHARED_MAILBOX=collection@tob-ins.com
AZURE_INITIATOR_EMAIL=initiator@tob-ins.com

# PostgreSQL Database (URL format)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Gotenberg PDF Lambda (public URL, routed through Squid proxy)
GOTENBERG_URL=https://xxx.lambda-url.ap-southeast-3.on.aws

# S3 Storage (via Gateway Endpoint)
S3_BUCKET=tob-soa-finance-prod
S3_PIPELINE_PREFIX=parquet

# Squid Proxy for external HTTPS (Graph API, Gotenberg)
HTTPS_PROXY=http://172.31.0.xxx:3128

# Workflow config
SOA_MAX_WORKERS=5
SOA_TEST_CUSTOMERS=00004162,00004829,00005017,00003758,00003390,00002844
SOA_SCHEDULE_DAYS=4,11,19,25
SOA_CC_RECIPIENTS=finance@tob-ins.com,mkt.nonleasing@tob-ins.com,mkt.directgroup@tob-ins.com
SOA_FALLBACK_EMAIL=collection@tob-ins.com
SOA_DEV_TEST_EMAIL=dev-test@tob-ins.com
