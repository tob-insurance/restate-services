{
  "name": "@restate-tob/soa-finance",
  "version": "0.0.1",
  "description": "SOA Finance service running with Restate",
  "main": "dist/app.local.js",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmitOnError",
    "typecheck": "tsc --noEmit",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "start": "node ./dist/app.local.js",
    "dev": "tsx watch ./src/app.local.ts",
    "test": "bun test src/",
    "clean": "rm -rf dist dist-lambda",
    "bundle": "tsdown src/app.local.ts --minify --sourcemap --platform node --target node22 --outDir dist --clean --no-dts",
    "postbundle": "cd dist && zip -r index.zip app.local.mjs*",
    "bundle:lambda": "tsdown",
    "postbundle:lambda": "cd dist-lambda && zip -r lambda.zip app.mjs* assets"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@azure/identity": "^4.13.1",
    "@restate-tob/postgres": "workspace:*",
    "@restate-tob/shared": "workspace:*",
    "@restatedev/restate-sdk": "^1.14.4",
    "hucre": "^0.5.1",
    "juice": "^11.1.1",
    "liquidjs": "^10.27.0",
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.14.2",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "varlock": "^1.2.0"
  }
}
