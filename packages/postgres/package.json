{
  "name": "@restate-tob/postgres",
  "version": "0.0.1",
  "description": "PostgreSQL connection utilities for Restate services",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmitOnError",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@restate-tob/shared": "workspace:*",
    "pg": "^8.21.0",
    "pg-cursor": "^2.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.14.2",
    "@types/pg-cursor": "^2.7.2",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3"
  }
}
